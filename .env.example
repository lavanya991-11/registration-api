# Copy this file to .env and fill in your real values. NEVER commit .env.

# ---- Azure AD app registration (Service-to-Service / client credentials) ----
TENANT_ID="your-azure-tenant-guid"
CLIENT_ID="your-app-registration-client-id"
CLIENT_SECRET="your-client-secret"

# ---- Business Central ----
BC_ENVIRONMENT=production
BC_COMPANY_ID="your-company-guid"
BC_TOKEN_URL="https://login.microsoftonline.com/your-azure-tenant-guid/oauth2/v2.0/token"
BC_SCOPE="https://api.businesscentral.dynamics.com/.default"

# ---- BC API location (defaults match the partnerRegistrations API) ----
BC_API_HOST=api.businesscentral.dynamics.com
BC_API_PUBLISHER=partnerPortal
BC_API_GROUP=partnerPortal
BC_API_VERSION=v2.0

# ---- Server ----
# PORT is provided by the host in production; 3000 is only a local default.
PORT=3000

# ---- Registration numbering ----
# true  = backend generates a unique regNo (works without BC No. Series config)
# false = leave blank so BC assigns it from Partner Portal Setup > Partner Reg. Nos.
GENERATE_REG_NO=true
REG_NO_PREFIX=WEB
